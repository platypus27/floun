{
  "homepage": "./",
  "name": "floun",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "file-saver": "^2.0.5",
    "pdf-lib": "^1.17.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "check:worker": "node --check build/background.js",
    "release:check": "npm run test && npm run build && npm run audit:prod && npm run typecheck && npm run check:worker",
    "fixture:server": "vite fixtures --host 127.0.0.1 --port 4174",
    "package:extension": "npm run release:check && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-extension.ps1",
    "release:artifact": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-release-artifact.ps1",
    "release:determinism": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-package-determinism.ps1",
    "store:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-store-readiness.ps1",
    "release:publish:check": "npm run release:ready && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-publish-readiness.ps1",
    "release:ready": "npm run package:extension && npm run release:artifact && npm run release:determinism && npm run store:check"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/chrome": "^0.0.307",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.14"
  }
}
